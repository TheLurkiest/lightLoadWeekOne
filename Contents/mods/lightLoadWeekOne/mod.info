name=Bandits Week One - lighter load
id=lightLoadWeekOne
poster=poster.png
icon=icon.png
author=TheLurkiest
modversion=1.0
description=alters the existing system of spawning and de-spawning of zombies and NPCs to ensure better use of limited hardware and fewer issues like lag or NPC's not rendering properly in crowded areas... designed specifically for anyone playing Bandits Week One that's still using an older PC (like myself), and anyone who wants to have zombie and NPC numbers accurately reflect what they should be based on player actions.
keybinding = Lighter Load: Keyboard.KEY_ESCAPE
keybinding = Lighter Load: Keyboard.KEY_8
keybinding = Lighter Load: Keyboard.KEY_9
keybinding = Lighter Load: Keyboard.KEY_NUMPAD8
keybinding = Lighter Load: Keyboard.KEY_NUMPAD9